# ── Secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
.venv/
*.egg-info/

# ── Pip-installed Lambda dependencies (pip install -t backend/ingestion/) ─
# These are build artifacts bundled into lambda_package.zip — not source code
backend/ingestion/*.dist-info/
backend/ingestion/boto3/
backend/ingestion/botocore/
backend/ingestion/certifi/
backend/ingestion/charset_normalizer/
backend/ingestion/dateutil/
backend/ingestion/dotenv/
backend/ingestion/idna/
backend/ingestion/jmespath/
backend/ingestion/requests/
backend/ingestion/s3transfer/
backend/ingestion/six.py
backend/ingestion/six-*.dist-info/
backend/ingestion/urllib3/
backend/ingestion/bin/

# ── Lambda build artifact ─────────────────────────────────────
lambda_package.zip

# ── Terraform ────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfvars
!*.tfvars.example
override.tf
override.tf.json

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env.local

# ── Build artifacts ────────────────────────────────────────────
build/

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
